{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Client (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=apps/client"],
      "port": 3000
    },
    {
      "name": "Server (Express + Socket.IO)",
      "runtimeExecutable": "npm",
