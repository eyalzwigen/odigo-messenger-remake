generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id         String   @id @db.Uuid
  username   String   @unique
  created_at DateTime @default(now())

  rooms                    UserRoom[]
  owned_rooms              Room[]          @relation("RoomOwner")
  messages                 Message[]
  friendship_a             Friendship[]    @relation("FriendshipA")
  friendship_b             Friendship[]    @relation("FriendshipB")
  sent_friend_requests     FriendRequest[] @relation("FriendRequestSender")
  received_friend_requests FriendRequest[] @relation("FriendRequestReceiver")
  sent_group_invites       GroupInvite[]   @relation("GroupInviteSender")
  received_group_invites   GroupInvite[]   @relation("GroupInviteReceiver")
}

model Room {
  id         String   @id @default(uuid()) @db.Uuid
  name       String?
  is_dm      Boolean  @default(false)
  created_at DateTime @default(now())

  owner_id String? @db.Uuid
  owner    User?   @relation("RoomOwner", fields: [owner_id], references: [id])

  members       UserRoom[]
  messages      Message[]
  friendship    Friendship?
  group_invites GroupInvite[]
}

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  content    String
  created_at DateTime @default(now())

  sender_id String @db.Uuid
  sender    User   @relation(fields: [sender_id], references: [id])

  room_id String @db.Uuid
  room    Room   @relation(fields: [room_id], references: [id])
}

model UserRoom {
  id        String   @id @default(uuid()) @db.Uuid
  joined_at DateTime @default(now())

  user_id String @db.Uuid
  user    User   @relation(fields: [user_id], references: [id])

  room_id String @db.Uuid
  room    Room   @relation(fields: [room_id], references: [id])

  @@unique([user_id, room_id])
}

model Friendship {
  id         String   @id @default(uuid()) @db.Uuid
  created_at DateTime @default(now())

  user_a_id String @db.Uuid
  user_a    User   @relation("FriendshipA", fields: [user_a_id], references: [id])

  user_b_id String @db.Uuid
  user_b    User   @relation("FriendshipB", fields: [user_b_id], references: [id])

  dm_room_id String? @unique @db.Uuid
  dm_room    Room?   @relation(fields: [dm_room_id], references: [id])

  @@unique([user_a_id, user_b_id])
}

model FriendRequest {
  id         String        @id @default(uuid()) @db.Uuid
  created_at DateTime      @default(now())
  status     RequestStatus @default(PENDING)

  sender_id String @db.Uuid
  sender    User   @relation("FriendRequestSender", fields: [sender_id], references: [id])

  receiver_id String @db.Uuid
  receiver    User   @relation("FriendRequestReceiver", fields: [receiver_id], references: [id])

  @@unique([sender_id, receiver_id])
}

model GroupInvite {
  id         String        @id @default(uuid()) @db.Uuid
  created_at DateTime      @default(now())
  status     RequestStatus @default(PENDING)

  room_id String @db.Uuid
  room    Room   @relation(fields: [room_id], references: [id])

  sender_id String @db.Uuid
  sender    User   @relation("GroupInviteSender", fields: [sender_id], references: [id])

  receiver_id String @db.Uuid
  receiver    User   @relation("GroupInviteReceiver", fields: [receiver_id], references: [id])

  @@unique([room_id, receiver_id])
}